		} else {
			// post and not a page.

			
		}

		if (isSVGregex.test(path)) {
			const svgImg = fs.readFileSync(fullpath, 'utf8');
			output = `<div class="${classname}">${svgImg}</div>`;

		} else {
			output = `<img src="${path}" alt="${alt}" loading="lazy" class="${classname}" />`;
