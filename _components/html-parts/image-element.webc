	let output = '';
	let type = false;
	
	const renderImage = (() => {
		const fs = require('fs');
		const isSVGregex = /\.svg$/i;

		post ? type = 'post' : type = 'PAGE';
		if (type === 'PAGE') {
			// was being used to test for when 11ty is rendering a page and not a post
			
			
			if (isSVGregex.test(path)) {
				console.log(path);
			}
			// if (isSVGregex.test(path)) {
